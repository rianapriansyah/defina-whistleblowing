# Copy to .env.local for local dev. On Vercel, add the same keys in Project Settings → Environment Variables.
# Required — must use VITE_ prefix (Vite exposes only these to the client bundle).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either the anon key name or the newer "publishable default" name from the Supabase dashboard:
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here

# Optional — storage bucket for complaint attachments (defaults to complaint-attachments)
# VITE_SUPABASE_COMPLAINT_BUCKET=complaint-attachments

# --- Admin stakeholder invites (Edge Function) ---
# 1. Run migration: supabase/migrations/20250323100000_stakeholder_invitations.sql
# 2. Deploy function: supabase functions deploy invite-stakeholder
# 3. Set admin users: Supabase Dashboard → Authentication → Users → User → app_metadata JSON: { "role": "admin" }
# 4. Edge Function secret (Supabase Dashboard → Edge Functions → Secrets):
#    INVITE_REDIRECT_URL=https://defina-whistleblowing.vercel.app/auth/complete-invite
#    Also add the same URL under Authentication → URL Configuration → Redirect URLs.
